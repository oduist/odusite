---
import Base from '@layouts/Base.astro';
import Badge from '@theme/Badge.astro';
import Button from '@theme/Button.astro';
import Input from '@theme/Input.astro';
import { apiFetch, OdusiteApiError } from '@lib/api/client';
import { TAGS_HEADER } from '@lib/cache';
import { getEnv } from '@lib/env';
import type { JobDetail } from '../types';

export const prerender = false;

const slug = Astro.params.slug ?? '';
let job: JobDetail;
try {
  job = await apiFetch<JobDetail>(Astro, `/jobs/${slug}`, { auth: false, cart: false });
} catch (error) {
  if (error instanceof OdusiteApiError && error.status === 404) {
    return Astro.rewrite('/404');
  }
  throw error;
}

// Odoo ships /web/image/... URLs inside the HTML — serve them via /img proxy.
const descriptionHtml = (job.description_html ?? '').replaceAll('/web/image', '/img');
const location = [job.location?.city, job.location?.country].filter(Boolean).join(', ');
const turnstileSiteKey = getEnv(Astro).PUBLIC_TURNSTILE_SITE_KEY;

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=600');
Astro.response.headers.set(TAGS_HEADER, `jobs,jobs:${job.id}`);
---

<Base title={job.seo?.title ?? job.name} description={job.seo?.description ?? undefined}>
  {turnstileSiteKey && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer
    ></script>
  )}

  <article class="od-section od-container">
    <header class="job-head">
      <p class="job-head__back"><a href="/jobs">← All positions</a></p>
      <h1>{job.name}</h1>
      <div class="job-head__chips">
        {job.department && <Badge>{job.department.name}</Badge>}
        {location && <Badge>{location}</Badge>}
        {job.employment_type && <Badge tone="info">{job.employment_type.name}</Badge>}
        {job.is_remote && <Badge tone="success">Remote</Badge>}
      </div>
    </header>

    <div class="job-layout">
      <div class="job-description" set:html={descriptionHtml} />

      <aside class="job-apply" aria-label="Apply for this position">
        <h2 class="job-apply__title">Apply for this position</h2>

        <form id="apply-form" enctype="multipart/form-data">
          <input type="hidden" name="job_id" value={String(job.id)} />
          <Input label="Full name" name="name" required autocomplete="name" />
          <Input label="Email" name="email" type="email" required autocomplete="email" />
          <Input label="Phone" name="phone" type="tel" required autocomplete="tel" />
          <Input
            label="LinkedIn profile"
            name="linkedin"
            type="url"
            placeholder="https://www.linkedin.com/in/…"
            autocomplete="url"
          />
          <Input
            label="Short introduction"
            name="short_introduction"
            textarea
            rows={5}
            placeholder="Tell us briefly why you are a great fit."
          />

          <div class="cv-field">
            <label class="cv-field__label" for="field-cv">
              CV / Resume <span class="cv-field__req" aria-hidden="true">*</span>
            </label>
            <input
              class="cv-field__input"
              id="field-cv"
              name="cv"
              type="file"
              accept=".pdf,.doc,.docx"
              required
            />
            <p class="cv-field__hint">PDF or Word document.</p>
          </div>

          {turnstileSiteKey && (
            <div id="job-apply-turnstile" class="cf-turnstile job-apply__turnstile" data-sitekey={turnstileSiteKey}></div>
          )}

          <p id="apply-error" class="job-apply__error" role="alert" hidden></p>
          <Button type="submit">Submit application</Button>
          <noscript>
            <p class="job-apply__noscript">JavaScript is required to submit this form.</p>
          </noscript>
        </form>

        <div id="apply-success" class="job-apply__success" hidden>
          <p class="job-apply__success-title">Application sent</p>
          <p>
            Thank you — we received your application and will get back to you as soon as
            possible.
          </p>
          <Button href="/jobs" variant="secondary">Back to all positions</Button>
        </div>
      </aside>
    </div>
  </article>
</Base>

<script>
  // Submit the application as multipart FormData to the same-origin endpoint;
  // the Odusite token never reaches the browser (proxying happens server-side).
  const form = document.getElementById('apply-form');
  if (form instanceof HTMLFormElement) {
    const errorBox = document.getElementById('apply-error');
    const successBox = document.getElementById('apply-success');
    const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');

    const showError = (message: string): void => {
      if (errorBox) {
        errorBox.textContent = message;
        errorBox.hidden = false;
      }
      // A consumed Turnstile token cannot be reused — reset for a retry.
      const turnstile = (window as unknown as { turnstile?: { reset?: (widget?: string) => void } }).turnstile;
      turnstile?.reset?.('#job-apply-turnstile');
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!form.reportValidity()) return;
      if (errorBox) errorBox.hidden = true;
      if (submit) submit.disabled = true;
      try {
        const response = await fetch('/api/jobs/apply', {
          method: 'POST',
          body: new FormData(form),
        });
        const payload = (await response.json().catch(() => ({}))) as {
          error?: { message?: string };
        };
        if (response.ok) {
          form.hidden = true;
          if (successBox) successBox.hidden = false;
        } else {
          showError(payload.error?.message ?? 'Could not submit your application. Please try again.');
        }
      } catch {
        showError('Network error. Please check your connection and try again.');
      } finally {
        if (submit) submit.disabled = false;
      }
    });
  }
</script>

<style>
  .job-head { margin-bottom: var(--od-space-6); }
  .job-head__back {
    font-size: var(--od-text-sm);
    margin-bottom: var(--od-space-3);
  }
  .job-head__chips {
    display: flex;
    gap: var(--od-space-2);
    flex-wrap: wrap;
  }

  .job-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(300px, 1fr);
    gap: var(--od-space-7);
    align-items: start;
  }
  @media (max-width: 900px) {
    .job-layout { grid-template-columns: 1fr; }
  }

  .job-description { min-width: 0; }
  .job-description :global(img) { border-radius: var(--od-radius-m); }
  .job-description :global(ul),
  .job-description :global(ol) { color: var(--od-fg-muted); }

  .job-apply {
    background: var(--od-bg-raised);
    border: 1px solid var(--od-border);
    border-radius: var(--od-radius-l);
    padding: var(--od-space-5);
  }
  .job-apply__title {
    font-size: var(--od-text-lg);
    margin-bottom: var(--od-space-4);
  }
  .job-apply__turnstile { margin-bottom: var(--od-space-4); }
  .job-apply__error {
    color: var(--od-danger);
    font-size: var(--od-text-sm);
    margin-bottom: var(--od-space-3);
  }
  .job-apply__noscript {
    color: var(--od-warning);
    font-size: var(--od-text-sm);
    margin-top: var(--od-space-3);
  }
  .job-apply__success-title {
    font-size: var(--od-text-lg);
    font-weight: 600;
    color: var(--od-success);
    margin-bottom: var(--od-space-2);
  }

  .cv-field {
    display: flex;
    flex-direction: column;
    gap: var(--od-space-1);
    margin-bottom: var(--od-space-4);
  }
  .cv-field__label {
    font-size: var(--od-text-sm);
    font-weight: 550;
    color: var(--od-fg);
  }
  .cv-field__req { color: var(--od-danger); }
  .cv-field__input {
    font: inherit;
    font-size: var(--od-text-sm);
    color: var(--od-fg-muted);
    background: var(--od-bg-inset);
    border: 1px solid var(--od-border);
    border-radius: var(--od-radius-m);
    padding: var(--od-space-2) var(--od-space-3);
  }
  .cv-field__input:focus { border-color: var(--od-accent); outline: none; }
  .cv-field__input::file-selector-button {
    font: inherit;
    color: var(--od-fg);
    background: var(--od-bg-hover);
    border: 1px solid var(--od-border-strong);
    border-radius: var(--od-radius-s);
    padding: var(--od-space-1) var(--od-space-3);
    margin-right: var(--od-space-3);
    cursor: pointer;
  }
  .cv-field__hint {
    margin: 0;
    font-size: var(--od-text-xs);
    color: var(--od-fg-subtle);
  }
</style>
