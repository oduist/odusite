---
import Badge from '@theme/Badge.astro';
import Card from '@theme/Card.astro';
import { imgUrl } from '@lib/api/client';
import { eventDateParts, formatEventRange } from '../lib/utils';
import type { EventListItem } from '../types';

interface Props {
  event: EventListItem;
}
const { event } = Astro.props;
const cover = imgUrl(event.cover);
const parts = eventDateParts(event.date_begin, event.timezone);
const location = [event.address?.city, event.address?.country].filter(Boolean).join(', ');
---

<Card href={`/events/${event.slug}`} padded={false} voiceLabel={event.name}>
  {cover && <img class="event-card__cover" src={cover} alt="" loading="lazy" decoding="async" />}
  <div class="event-card__body">
    <div class="event-card__date" aria-hidden="true">
      <span class="event-card__day">{parts.day}</span>
      <span class="event-card__month">{parts.month}</span>
    </div>
    <div class="event-card__info">
      <h3 class="event-card__title">{event.name}</h3>
      <p class="event-card__when">{formatEventRange(event.date_begin, event.date_end, event.timezone)}</p>
      {location && <p class="event-card__where">{location}</p>}
      {(event.is_ongoing || event.is_done || event.tags.length > 0) && (
        <div class="event-card__tags">
          {event.is_ongoing && <Badge tone="success">Ongoing</Badge>}
          {event.is_done && <Badge tone="neutral">Past</Badge>}
          {event.tags.map((tag) => <Badge tone="accent">{tag.name}</Badge>)}
        </div>
      )}
    </div>
  </div>
</Card>

<style>
  .event-card__cover {
    width: 100%;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    border-bottom: 1px solid var(--od-border);
  }
  .event-card__body {
    display: flex;
    gap: var(--od-space-4);
    padding: var(--od-space-4) var(--od-space-5) var(--od-space-5);
  }
  .event-card__date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 56px;
    height: 64px;
    flex-shrink: 0;
    background: var(--od-bg-inset);
    border: 1px solid var(--od-border);
    border-radius: var(--od-radius-m);
  }
  .event-card__day {
    font-size: var(--od-text-xl);
    font-weight: 650;
    line-height: 1.1;
    color: var(--od-fg);
  }
  .event-card__month {
    font-size: var(--od-text-xs);
    text-transform: uppercase;
    letter-spacing: var(--od-tracking-wide);
    color: var(--od-accent);
  }
  .event-card__info {
    min-width: 0;
  }
  .event-card__title {
    font-size: var(--od-text-lg);
    margin-bottom: var(--od-space-1);
    color: var(--od-fg);
  }
  .event-card__when {
    margin: 0 0 var(--od-space-1);
    font-size: var(--od-text-sm);
    color: var(--od-fg-muted);
  }
  .event-card__where {
    margin: 0 0 var(--od-space-2);
    font-size: var(--od-text-sm);
    color: var(--od-fg-subtle);
  }
  .event-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--od-space-1);
  }
</style>
