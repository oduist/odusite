---
// Sign-up page: plain form POST to /api/auth/signup.
import Button from '@theme/Button.astro';
import Input from '@theme/Input.astro';
import AuthShell from '../components/AuthShell.astro';
import Notice from '../components/Notice.astro';
import { safePath } from '../lib';

export const prerender = false;

const next = safePath(Astro.url.searchParams.get('next'), '/portal');
if (Astro.locals.user) return Astro.redirect(next, 303);

const error = Astro.url.searchParams.get('error');
const errorMessages: Record<string, string> = {
  exists: 'An account with this email already exists. Try signing in instead.',
  disabled: 'Self-registration is disabled on this site. Contact us to get an invitation.',
  validation: 'Please check the entered values and try again.',
  unknown: 'Something went wrong. Please try again.',
};
const errorMessage = error ? (errorMessages[error] ?? errorMessages.unknown) : null;
const disabled = error === 'disabled';

// Double opt-in: after a successful signup the account is created but
// inactive until the emailed confirmation link is used.
const sent = Astro.url.searchParams.get('sent') === '1';
const sentEmail = Astro.url.searchParams.get('email') ?? '';
---

<AuthShell title="Create account" heading={sent ? 'Check your email' : 'Create account'} subtitle={sent ? undefined : 'Register to track your orders, invoices and projects.'}>
  {sent ? (
    <Fragment>
      <Notice tone="success">
        {sentEmail
          ? `We sent a confirmation link to ${sentEmail}. Click it to activate your account, then sign in.`
          : 'We sent you a confirmation link. Click it to activate your account, then sign in.'}
      </Notice>
      <p class="signup__hint">Didn't get the email? Check your spam folder or resend it.</p>
      <form method="post" action="/api/auth/resend">
        {sentEmail ? (
          <input type="hidden" name="email" value={sentEmail} />
        ) : (
          <Input label="Email" name="email" type="email" required autocomplete="email" placeholder="you@example.com" />
        )}
        <div class="signup__actions">
          <Button type="submit" size="lg" class="signup__submit">Resend confirmation email</Button>
        </div>
      </form>
      <div class="signup__links">
        <span>Already confirmed?</span>
        <a href="/login">Sign in</a>
      </div>
    </Fragment>
  ) : (
    <Fragment>
      {errorMessage && <Notice tone={disabled ? 'warning' : 'danger'}>{errorMessage}</Notice>}

      {!disabled && (
        <form method="post" action="/api/auth/signup">
          <input type="hidden" name="next" value={next} />
          <Input label="Name" name="name" required autocomplete="name" placeholder="Your full name" />
          <Input label="Email" name="email" type="email" required autocomplete="email" placeholder="you@example.com" />
          <Input label="Password" name="password" type="password" required autocomplete="new-password" />
          <div class="signup__actions">
            <Button type="submit" size="lg" class="signup__submit">Create account</Button>
          </div>
        </form>
      )}

      <div class="signup__links">
        <span>Already registered?</span>
        <a href="/login">Sign in</a>
      </div>
    </Fragment>
  )}
</AuthShell>

<style>
  .signup__actions { margin-top: var(--od-space-2); }
  :global(.signup__submit) { width: 100%; }
  .signup__hint {
    font-size: var(--od-text-sm);
    color: var(--od-fg-subtle);
    margin-bottom: var(--od-space-4);
  }
  .signup__links {
    display: flex;
    gap: var(--od-space-2);
    margin-top: var(--od-space-5);
    font-size: var(--od-text-sm);
    color: var(--od-fg-subtle);
  }
</style>
