---
import 'virtual:odusite/theme.css';
import { ClientRouter } from 'astro:transitions';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import SEO from '@components/SEO.astro';
import { getLocaleInfo, localizePath } from '@lib/i18n';

interface Props {
  title: string;
  description?: string;
  ogImage?: string | null;
  ogType?: string;
  noindex?: boolean;
}
const props = Astro.props;

// After the middleware strips the locale prefix, Astro.url.pathname is already
// the locale-neutral path — use it to build hreflang alternates.
const info = await getLocaleInfo(Astro).catch(() => null);
const neutralPath = Astro.url.pathname;
---

<!doctype html>
<html lang={Astro.locals.lang?.split('_')[0] ?? 'en'} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO {...props} />
    {info && info.languages.length > 1 && info.languages.map((l) => (
      <link
        rel="alternate"
        hreflang={l.url_code}
        href={new URL(localizePath(neutralPath, l.url_code, info), Astro.url).toString()}
      />
    ))}
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
