---
interface Props {
  href?: string;
  padded?: boolean;
  class?: string;
  // Marks this card as a canonical entity link for the voice assistant, which
  // opens it by this visible name via the click_on_page tool. See
  // specs/site/04-voice-assistant.md.
  voiceLabel?: string;
}
const { href, padded = true, class: className = '', voiceLabel } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  class:list={['od-card', { 'od-card--padded': padded, 'od-card--link': !!href }, className]}
  href={href}
  data-voice-label={href ? voiceLabel : undefined}
>
  <slot />
</Tag>

<style>
  .od-card {
    display: block;
    background: var(--od-bg-raised);
    border: 1px solid var(--od-border);
    border-radius: var(--od-radius-l);
    color: inherit;
    overflow: hidden;
    transition: border-color var(--od-dur-base) var(--od-ease);
  }
  .od-card--padded { padding: var(--od-space-5); }
  .od-card--link:hover { border-color: var(--od-border-strong); color: inherit; }
</style>
