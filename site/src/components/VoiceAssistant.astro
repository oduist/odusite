---
// Voice assistant island (ElevenLabs Conversational AI). Rendered by Base only
// when the server has an agent configured. The API key stays server-side; the
// browser fetches a short-lived signed URL from /api/voice/signed-url and drives
// a WebRTC/WebSocket conversation. The agent can call two client tools —
// navigate(path) and search_site(query) — wired to the View Transitions router,
// so the assistant moves the visitor around the site hands-free.
//
// The widget is transition:persist so an ongoing call survives page navigation.
// The SDK is dynamically imported on first use, so an idle visitor pays no JS.
---

<div id="od-voice" class="od-voice" transition:persist>
  <button
    id="od-voice-btn"
    class="od-voice__btn"
    type="button"
    aria-label="Start the AI Voice Navigator"
    aria-pressed="false"
  >
    <span class="od-voice__ring" aria-hidden="true"></span>
    <span class="od-voice__icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="3" width="6" height="11" rx="3" />
        <path d="M6 11a6 6 0 0 0 12 0" />
        <path d="M12 17v4" />
      </svg>
    </span>
    <span class="od-voice__text">
      <span class="od-voice__title">
        AI Voice Navigator
        <span class="od-voice__badge" aria-hidden="true">NEW</span>
      </span>
      <span id="od-voice-status" class="od-voice__status" role="status" aria-live="polite"
        >Ask — I'll take you there</span
      >
    </span>
  </button>
</div>

<script>
  import { navigate } from 'astro:transitions/client';
  import { VOICE_TOOL_NAMES } from '../voice/tools.mjs';

  // The live conversation is kept on window so it survives both View Transitions
  // (the widget is transition:persist) and any re-run of this module script.
  declare global {
    interface Window {
      __odVoiceConv?: { endSession: () => Promise<void> } | null;
      __odVoiceAudioPatched?: boolean;
    }
  }

  const IDLE_STATUS = "Ask — I'll take you there";

  // --- Keep audio playing -------------------------------------------------
  // The ElevenLabs SDK plays agent audio through a Web Audio AudioContext it
  // owns and does not expose. Browsers suspend an AudioContext when the tab is
  // backgrounded (and, on some engines, after a stretch of inactivity): the
  // WebSocket keeps running — so the call log still shows the agent talking —
  // but no sound comes out. We wrap the AudioContext constructor to collect the
  // instances the SDK creates, then resume any that fall asleep whenever the
  // page is shown again and on a short interval while a call is live.
  const audioContexts = new Set<AudioContext>();
  function captureAudioContexts() {
    const w = window as unknown as {
      AudioContext?: typeof AudioContext;
      webkitAudioContext?: typeof AudioContext;
      __odVoiceAudioPatched?: boolean;
    };
    if (w.__odVoiceAudioPatched) return;
    const Native = w.AudioContext || w.webkitAudioContext;
    if (!Native) return;
    const Patched = function (this: unknown, ...args: unknown[]) {
      const ctx = new (Native as unknown as new (...a: unknown[]) => AudioContext)(...args);
      audioContexts.add(ctx);
      return ctx;
    } as unknown as typeof AudioContext;
    Patched.prototype = Native.prototype;
    if (w.AudioContext) w.AudioContext = Patched;
    if (w.webkitAudioContext) w.webkitAudioContext = Patched;
    w.__odVoiceAudioPatched = true;
  }
  function resumeAudio() {
    for (const ctx of audioContexts) {
      if (ctx.state === 'suspended') void ctx.resume().catch(() => {});
    }
  }
  let keepAwake: ReturnType<typeof setInterval> | null = null;
  function startKeepAwake() {
    if (keepAwake) return;
    keepAwake = setInterval(resumeAudio, 3000);
  }
  function stopKeepAwake() {
    if (keepAwake) clearInterval(keepAwake);
    keepAwake = null;
    for (const ctx of audioContexts) audioContexts.delete(ctx);
  }
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible' && window.__odVoiceConv) resumeAudio();
  });

  // --- Open-by-name on the current page -----------------------------------
  // click_on_page lets the agent open a specific visible entity (product, post,
  // event, forum thread…) without knowing its URL. Blocks mark their canonical
  // entity links with `data-voice-label="<visible name>"`; we scan those inside
  // <main>, fuzzy-match the spoken phrase, and SPA-navigate to the one link.
  // Until a block is annotated we fall back to internal links inside <main>.
  type VoiceTarget = { label: string; href: string | null; el: Element; norm: string };

  function normalizeLabel(s: string): string {
    return s
      .normalize('NFKD')
      .replace(/[\u0300-\u036f]/g, '') // strip diacritics
      .toLowerCase()
      .replace(/[^\p{L}\p{N}]+/gu, ' ') // punctuation → space
      .trim()
      .replace(/\s+/g, ' ');
  }

  // Same-origin internal path only — never external URLs or javascript: links.
  function internalHref(el: Element): string | null {
    const a = el.matches('a[href]') ? el : el.closest('a[href]');
    const href = a?.getAttribute('href') ?? null;
    return href && href.startsWith('/') ? href : null;
  }

  function collectTargets(): VoiceTarget[] {
    const scope = document.querySelector('main') ?? document.body;
    const out: VoiceTarget[] = [];
    const seen = new Set<string>();
    const push = (rawLabel: string, href: string | null, el: Element) => {
      const label = rawLabel.trim().replace(/\s+/g, ' ');
      if (!label) return;
      const key = `${label}\u0000${href ?? ''}`;
      if (seen.has(key)) return;
      seen.add(key);
      out.push({ label, href, el, norm: normalizeLabel(label) });
    };
    // Primary: explicitly annotated entity links.
    scope.querySelectorAll('[data-voice-label]').forEach((el) => {
      push(el.getAttribute('data-voice-label') ?? el.textContent ?? '', internalHref(el), el);
    });
    // Fallback until every block is annotated: internal links inside main.
    if (out.length === 0) {
      scope.querySelectorAll('a[href^="/"]').forEach((a) => {
        const text = (a.getAttribute('aria-label') || a.textContent || '').trim();
        if (text.length >= 2) push(text, a.getAttribute('href'), a);
      });
    }
    return out;
  }

  // Tiered match: exact → edge (prefix either way) → substring. Speech rarely
  // equals the label verbatim, so we widen only when a tighter tier is empty.
  function matchTargets(cands: VoiceTarget[], q: string): VoiceTarget[] {
    const exact = cands.filter((c) => c.norm === q);
    if (exact.length) return exact;
    const edge = cands.filter((c) => c.norm.startsWith(q) || q.startsWith(c.norm));
    if (edge.length) return edge;
    return cands.filter((c) => c.norm.includes(q) || q.includes(c.norm));
  }

  function initVoice() {
    const btn = document.getElementById('od-voice-btn');
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = '1';

    const statusEl = document.getElementById('od-voice-status');
    const setStatus = (s: string) => {
      if (statusEl) statusEl.textContent = s;
    };
    const setActive = (on: boolean) => {
      btn.setAttribute('aria-pressed', String(on));
      btn.classList.toggle('is-active', on);
    };
    // Clears call state only; the caller sets the status message so an error
    // string isn't wiped immediately after being shown.
    const reset = () => {
      window.__odVoiceConv = null;
      setActive(false);
      stopKeepAwake();
    };

    const clientTools = {
      navigate: async ({ path }: { path?: string }) => {
        if (typeof path === 'string' && path.startsWith('/')) {
          await navigate(path);
          return `Opened ${path}`;
        }
        return 'That path is not valid.';
      },
      search_site: async ({ query }: { query?: string }) => {
        const q = String(query ?? '').trim();
        if (!q) return 'No search query given.';
        await navigate(`/search?q=${encodeURIComponent(q)}`);
        return `Showing results for ${q}.`;
      },
      click_on_page: async ({ text }: { text?: string }) => {
        const q = normalizeLabel(String(text ?? ''));
        if (!q) return 'No item name was given.';
        const targets = collectTargets();
        if (!targets.length) {
          return 'There is nothing to open on this page. Navigate to a section or search first.';
        }
        const matches = matchTargets(targets, q);
        if (matches.length === 0) {
          const sample = targets.slice(0, 8).map((t) => t.label).join('; ');
          return `Couldn't find "${text}" on this page. Visible items include: ${sample}.`;
        }
        if (matches.length > 1) {
          const labels = matches.slice(0, 6).map((m) => m.label).join('; ');
          return `Several items match "${text}": ${labels}. Which one?`;
        }
        const target = matches[0];
        if (target.href) {
          await navigate(target.href);
        } else {
          (target.el as HTMLElement).click();
        }
        return `Opened ${target.label}.`;
      },
    };

    // Drift guard: every tool declared for the agent must have a handler here.
    if (import.meta.env.DEV) {
      for (const name of VOICE_TOOL_NAMES) {
        if (!(name in clientTools)) {
          console.warn(`[voice] declared tool "${name}" has no client handler`);
        }
      }
    }

    btn.addEventListener('click', async () => {
      // Any click is a user gesture — a good moment to wake sleeping audio.
      resumeAudio();
      if (window.__odVoiceConv) {
        try {
          await window.__odVoiceConv.endSession();
        } catch {
          /* ignore */
        }
        reset();
        setStatus(IDLE_STATUS);
        return;
      }
      setStatus('Connecting…');
      try {
        const res = await fetch('/api/voice/signed-url');
        if (!res.ok) {
          setStatus('Voice unavailable');
          return;
        }
        const { signed_url: signedUrl } = (await res.json()) as { signed_url: string };
        captureAudioContexts();
        const { Conversation } = await import('@elevenlabs/client');
        window.__odVoiceConv = await Conversation.startSession({
          signedUrl,
          clientTools,
          onStatusChange: ({ status }: { status: string }) => {
            if (status === 'connected') {
              setActive(true);
              setStatus('Listening…');
              startKeepAwake();
              resumeAudio();
            } else if (status === 'disconnected') {
              reset();
              setStatus(IDLE_STATUS);
            }
          },
          onModeChange: ({ mode }: { mode: string }) => {
            // The agent just started speaking — make sure output is awake.
            if (mode === 'speaking') resumeAudio();
            setStatus(mode === 'speaking' ? 'Speaking…' : 'Listening…');
          },
          onError: () => {
            reset();
            setStatus('Something went wrong');
          },
        });
      } catch {
        // Most often a denied microphone permission.
        reset();
        setStatus('Microphone needed');
      }
    });
  }

  document.addEventListener('astro:page-load', initVoice);
</script>

<style>
  .od-voice {
    position: fixed;
    right: var(--od-space-5, 1.25rem);
    bottom: var(--od-space-5, 1.25rem);
    z-index: 80;
  }
  .od-voice__btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--od-space-3, 0.75rem);
    padding: 0.4rem 1.1rem 0.4rem 0.4rem;
    border-radius: var(--od-radius-full, 999px);
    border: 1px solid color-mix(in srgb, #ffffff 22%, transparent);
    color: #fff;
    background: linear-gradient(
      135deg,
      var(--od-accent, #6366f1),
      color-mix(in srgb, var(--od-accent, #6366f1) 45%, #d946ef)
    );
    cursor: pointer;
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.35),
      0 0 0 0 color-mix(in srgb, var(--od-accent, #6366f1) 60%, transparent);
    transition:
      transform 0.16s ease,
      box-shadow 0.25s ease,
      filter 0.16s ease;
  }
  .od-voice__btn:hover {
    transform: translateY(-2px);
    box-shadow:
      0 14px 38px rgba(0, 0, 0, 0.42),
      0 0 26px color-mix(in srgb, var(--od-accent, #6366f1) 55%, transparent);
    filter: saturate(1.1);
  }
  .od-voice__btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  /* Attention ring: a soft pulse that draws the eye while idle. */
  .od-voice__ring {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--od-accent, #6366f1) 70%, transparent);
    animation: od-voice-attention 2.8s ease-out infinite;
  }

  .od-voice__icon {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    flex: none;
    border-radius: var(--od-radius-full, 999px);
    background: color-mix(in srgb, #ffffff 22%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, #ffffff 30%, transparent);
  }
  .od-voice__text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    text-align: left;
  }
  .od-voice__title {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: var(--od-text-sm, 0.9rem);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .od-voice__badge {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    padding: 0.05rem 0.3rem;
    border-radius: var(--od-radius-full, 999px);
    background: #fff;
    color: var(--od-accent, #6366f1);
    text-transform: uppercase;
  }
  .od-voice__status {
    font-size: 0.72rem;
    color: color-mix(in srgb, #ffffff 82%, transparent);
    white-space: nowrap;
  }

  /* Active call: switch to a "live / tap to stop" look. */
  .od-voice__btn.is-active {
    background: linear-gradient(
      135deg,
      var(--od-danger, #ef4444),
      color-mix(in srgb, var(--od-danger, #ef4444) 60%, #f59e0b)
    );
  }
  .od-voice__btn.is-active .od-voice__badge {
    color: var(--od-danger, #ef4444);
  }
  .od-voice__btn.is-active .od-voice__ring {
    animation: od-voice-live 1.5s ease-in-out infinite;
  }

  @keyframes od-voice-attention {
    0% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--od-accent, #6366f1) 55%, transparent);
    }
    70%,
    100% {
      box-shadow: 0 0 0 14px transparent;
    }
  }
  @keyframes od-voice-live {
    0%,
    100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--od-danger, #ef4444) 55%, transparent);
    }
    50% {
      box-shadow: 0 0 0 12px transparent;
    }
  }

  @media (max-width: 30rem) {
    .od-voice__status {
      display: none;
    }
    .od-voice__title {
      font-size: 0.82rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .od-voice__ring {
      animation: none;
    }
    .od-voice__btn {
      transition: none;
    }
  }
</style>
