---
// Data-driven language switcher. Renders nothing unless the Odoo site has more
// than one language enabled. Each option links to the same page under its
// locale prefix (default locale ⇒ no prefix); the middleware persists the
// choice in a cookie so subsequent navigation stays localized. No client JS —
// a native <details> disclosure keeps it accessible and View Transitions-safe.
import { getLocaleInfo } from '@lib/i18n';

const info = await getLocaleInfo(Astro).catch(() => null);
const current = Astro.locals.locale ?? info?.defaultUrlCode ?? 'en';
const neutralPath = Astro.url.pathname; // already locale-stripped by middleware
// Always link with an explicit locale prefix (incl. the default): selecting the
// default sends `/en/...`, which the middleware turns into "reset to default +
// redirect to the clean path", so switching back out of a language works.
const localeHref = (urlCode: string) =>
  `/${urlCode}${neutralPath === '/' ? '' : neutralPath}`;
---

{info && info.languages.length > 1 && (
  <details class="od-lang">
    <summary aria-label="Change language">{current.toUpperCase()}</summary>
    <ul>
      {info.languages.map((l) => (
        <li>
          <a
            href={localeHref(l.url_code)}
            hreflang={l.url_code}
            class:list={{ active: l.url_code === current }}
          >{l.name}</a>
        </li>
      ))}
    </ul>
  </details>
)}

<style>
  .od-lang { position: relative; }
  .od-lang > summary {
    list-style: none;
    cursor: pointer;
    font-size: var(--od-text-sm);
    font-weight: 600;
    color: var(--od-fg-muted);
    padding: var(--od-space-1) var(--od-space-2);
    border-radius: var(--od-radius-s);
    user-select: none;
  }
  .od-lang > summary::-webkit-details-marker { display: none; }
  .od-lang > summary:hover { color: var(--od-fg); }
  .od-lang[open] > summary { color: var(--od-accent); }
  .od-lang ul {
    position: absolute;
    right: 0;
    top: calc(100% + var(--od-space-2));
    min-width: 8rem;
    margin: 0;
    padding: var(--od-space-1);
    list-style: none;
    background: var(--od-bg-raised);
    border: 1px solid var(--od-border);
    border-radius: var(--od-radius-m);
    box-shadow: var(--od-shadow-m);
    z-index: 60;
  }
  .od-lang li a {
    display: block;
    padding: var(--od-space-2) var(--od-space-3);
    border-radius: var(--od-radius-s);
    font-size: var(--od-text-sm);
    color: var(--od-fg-muted);
  }
  .od-lang li a:hover { background: var(--od-bg-hover); color: var(--od-fg); }
  .od-lang li a.active { color: var(--od-accent); font-weight: 600; }
</style>
