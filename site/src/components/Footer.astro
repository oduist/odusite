---
import config from 'virtual:odusite/config';
import { getSiteConfig } from '@lib/api/base';

// Dynamic import keeps the newsletter block's component (and its inline
// script) out of the bundle when the block is disabled — a static import
// would be processed by Vite regardless of the condition.
const { default: NewsletterForm } = config.blocks.newsletter
  ? await import('../blocks/newsletter/components/NewsletterForm.astro')
  : { default: null };

const site = await getSiteConfig(Astro).catch(() => null);
const year = new Date().getFullYear();
const socials = Object.entries(site?.social ?? {}).filter(([, url]) => !!url) as [string, string][];
---

<footer class="od-footer">
  <div class="od-container od-footer__inner">
    <div>
      <p class="od-footer__brand">{site?.name ?? 'Odusite'}</p>
      {site?.company && (
        <p class="od-footer__meta">
          {[site.company.street, site.company.city, site.company.country].filter(Boolean).join(', ')}
          {site.company.email && <><br />{site.company.email}</>}
          {site.company.phone && <><br />{site.company.phone}</>}
        </p>
      )}
    </div>
    <nav class="od-footer__nav" aria-label="Footer">
      {config.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    {(NewsletterForm || socials.length > 0) && (
      <div class="od-footer__aside">
        {NewsletterForm && <NewsletterForm />}
        {socials.length > 0 && (
          <nav class="od-footer__nav" aria-label="Social">
            {socials.map(([name, url]) => (
              <a href={url} rel="noopener noreferrer" target="_blank">
                {name[0].toUpperCase() + name.slice(1)}
              </a>
            ))}
          </nav>
        )}
      </div>
    )}
  </div>
  <div class="od-container od-footer__legal">
    <span>© {year} {site?.company?.name ?? site?.name ?? ''}</span>
    <a
      class="od-footer__github"
      href="https://github.com/oduist/odusite"
      rel="noopener noreferrer"
      target="_blank"
    >
      <svg aria-hidden="true" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path>
      </svg>
      <span>GitHub</span>
    </a>
  </div>
</footer>

<style>
  .od-footer {
    margin-top: auto;
    border-top: 1px solid var(--od-border);
    background: var(--od-bg-inset);
    padding-block: var(--od-space-7) var(--od-space-5);
  }
  .od-footer__inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--od-space-6);
  }
  @media (max-width: 720px) {
    .od-footer__inner { grid-template-columns: 1fr; }
  }
  .od-footer__brand {
    font-family: var(--od-font-display);
    font-weight: 400;
    font-synthesis: none;
    font-size: var(--od-text-xl);
    letter-spacing: -0.01em;
    color: var(--od-fg);
    margin-bottom: var(--od-space-2);
  }
  .od-footer__meta {
    font-size: var(--od-text-sm);
    color: var(--od-fg-subtle);
  }
  .od-footer__aside {
    display: flex;
    flex-direction: column;
    gap: var(--od-space-4);
  }
  .od-footer__nav {
    display: flex;
    flex-direction: column;
    gap: var(--od-space-2);
  }
  .od-footer__nav a {
    color: var(--od-fg-muted);
    font-size: var(--od-text-sm);
  }
  .od-footer__nav a:hover { color: var(--od-fg); }
  .od-footer__legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--od-space-3);
    margin-top: var(--od-space-6);
    padding-top: var(--od-space-4);
    border-top: 1px solid var(--od-border);
    font-size: var(--od-text-xs);
    color: var(--od-fg-subtle);
  }
  .od-footer__github {
    display: inline-flex;
    align-items: center;
    gap: var(--od-space-2);
    color: var(--od-fg-muted);
  }
  .od-footer__github:hover { color: var(--od-fg); }
</style>
