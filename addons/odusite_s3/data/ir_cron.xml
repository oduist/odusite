<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Background migration of existing local attachments to S3.
             Inactive by default; driven by the Start/Stop buttons in
             Settings (which flip odusite.s3.migrate_active and trigger it). -->
        <record id="ir_cron_odusite_s3_migrate" model="ir.cron">
            <field name="name">Odusite S3: migrate local attachments to S3</field>
            <field name="model_id" ref="base.model_ir_attachment"/>
            <field name="state">code</field>
            <field name="code">model._cron_odusite_s3_migrate()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
