<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.odusite</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='website']" position="inside">
                <block title="Odusite" name="odusite_block">
                    <setting string="API Token" help="Shared secret sent by the Astro site in the X-Odusite-Token header. Auto-generated on install.">
                        <field name="odusite_token" password="True"/>
                    </setting>
                    <setting string="Site URL" help="Public base URL of the Astro site (links in emails, webhook target).">
                        <field name="odusite_site_url" placeholder="https://www.example.com"/>
                    </setting>
                    <setting string="Revalidate Secret" help="HMAC secret for cache-invalidation webhooks (ODUSITE_REVALIDATE_SECRET on the site).">
                        <field name="odusite_revalidate_secret" password="True"/>
                    </setting>
                    <setting string="Website" help="Odoo website whose context the API exposes.">
                        <field name="odusite_website_id"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
